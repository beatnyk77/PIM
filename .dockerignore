# ==========================================
# PIM Docker Ignore: Monorepo Clean Context
# ==========================================

# Exclude Git metadata and IDE settings
.git
.github
.idea
.vscode
.DS_Store

# Exclude local dependencies and generated outputs
node_modules
app/node_modules
backend/node_modules
backend/dist

# Exclude native client-side caches and builds
app/.expo
app/.tmp-tests
app/dist
app/web-build
app/ios
app/android
app/assets

# Exclude logs and local-only files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
.env
.env.*
!.env.example
